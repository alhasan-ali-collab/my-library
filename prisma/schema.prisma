generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../library.db"
}

model Book {
  id          Int     @id @default(autoincrement())
  term        String
  grade       String
  subject     String
  resource    String?
  title       String
  image       String
  file        String
  description String
  views       Int     @default(0)
}